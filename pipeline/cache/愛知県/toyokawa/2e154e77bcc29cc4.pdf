        <script>
        $(function() {
          var form = $('form#SimpleQuestionnaireForm85565');
          function setToken(name, value) {
            form.find('.hidden_token_form').attr('name', name);
            form.find('.hidden_token_form').attr('value', value);
          }
          function createCallback() {
            return function(e) {
              setToken('', '');
              $.getJSON('//www.city.toyokawa.lg.jp/cgi-bin/inquiry.php/1/init_simple', function(json) {
                setToken(json.name, json.value);
                form.unbind('submit');
                form.submit();
              });
              return false;
            }
          }
          form.submit(createCallback())
        });
        </script>
