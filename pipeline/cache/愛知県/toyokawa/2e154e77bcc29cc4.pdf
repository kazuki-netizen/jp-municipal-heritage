  } else {
    /*検索ID取得*/
    $.ajax({
      type: 'get',
      url: '//' + cms_api_domain + '/' + API_PATH_TYPE + '/page/get_page_contents.json',
      data: {
        app_version: cms_app_version,
        app_id: cms_app_id,
        token: cms_api_token,
        page_no: inputText
      },
      dataType : 'json',
      success: function(data) {
        if(data.success && data.data)
          location.href = data.data.page_path;//画面遷移
