                    <div class="item">
            <input type="hidden" name="ref" value="https://www.city.ritto.lg.jp/soshiki/kyoiku/sports_bunka/bunkazai/9692.html"/>
            <input type="hidden" name="page_no" value="9692"/>
            <input type="hidden" name="cmd:send" value="send"/>
            <input class="hidden_token_form" type="hidden" name="token" value="" />
            <input type="submit" value="送信" />
          </div>
        </form>
        <script data-cfasync="false" src="/cdn-cgi/scripts/5c5dd728/cloudflare-static/email-decode.min.js"></script><script>
        $(function() {
          var form = $('form#SimpleQuestionnaireForm175544');
          function setToken(name, value) {
            form.find('.hidden_token_form').attr('name', name);
            form.find('.hidden_token_form').attr('value', value);
          }
          function createCallback() {
            return function(e) {
              setToken('', '');
              $.getJSON('//www.city.ritto.lg.jp/cgi-bin/inquiry.php/1/init_simple', function(json) {
                setToken(json.name, json.value);
                form.unbind('submit');
                form.submit();
              });
              return false;
            }
          }
          form.submit(createCallback())
        });
        </script>
      </div>
