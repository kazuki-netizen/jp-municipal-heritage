  <p id="pagetop"><a href="#wrapper" class="scroll"><img src="//www.town.minowa.lg.jp/theme/base/img_common/footer_pagetop.png" alt="ページの先頭へ"></a></p>
  <div class="in">
    <div class="box">
      <div class="left-area">

        <div id="footer-logo">
          <span class="visually-hidden">箕輪町役場</span>
          <img src="//www.town.minowa.lg.jp/theme/base/img_common/pc_footer_logo.png" alt="" class="view-pc">
          <img src="//www.town.minowa.lg.jp/theme/base/img_common/sp_footer_logo.png" alt="" class="view-sp">
        </div>
        <p class="houjin-bangou">法人番号 7000020203831</p>
