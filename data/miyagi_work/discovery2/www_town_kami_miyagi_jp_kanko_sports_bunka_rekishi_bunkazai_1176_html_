        var entity = template.clone();
        entity.find('.pageLink').attr('href', item.url).text(item.page_name);
        entity.find('.pageDescription').text(item.description);
        list.append(entity);
        count++;
      }
      if (count > 0) {
        block.css('display', '');
      }
      templateOrig.remove();
    });
  });
});
