    }

    $.getJSON(url, function(json) {
      var templateOrig = block.find('.headerNaviPageTemplate');
      if (templateOrig.length == 0) {
        return;
      }
      var template = templateOrig.clone().removeClass('headerNaviPageTemplate').addClass('pageEntity').css('display', '');
