  var today = new Date();
  var cal_year = today.getYear();
  var cal_month = today.getMonth() + 1;
  var cal_day = today.getDate();
  if (cal_year < 1900) cal_year += 1900;
  var length = data.length;
  var isEvent = new Array();
  for(var i=1;i<=31;i++) isEvent[i] = false;
  for(var i=0;i<length;i++){
    obj = data[i];
    if(obj.month - cal_month == 0) isEvent[obj.date] = true;
  }
  
 _cal = writeCal(cal_year,cal_month,cal_day,isEvent);

  var c = new Array();
  var length = data.length;
  for(var i=0;i<length;i++){
     obj = data[i];
     key = new Date(obj.year,obj.month-1,obj.date,0,0).getTime()/1000;
     if(typeof c[key] === "undefined") c[key] = "";

_tag = '<img src="/materials/img/event/event_icon05.png" alt="">';
if(obj.cate === 'event_icon11') _tag = '<img src="/materials/img/event/event_icon11.png" alt="">';
if(obj.cate === 'event_icon12') _tag = '<img src="/materials/img/event/event_icon12.png" alt="">';
if(obj.cate === 'event_icon02') _tag = '<img src="/materials/img/event/event_icon02.png" alt="">';
if(obj.cate === 'event_icon13') _tag = '<img src="/materials/img/event/event_icon13.png" alt="">';
if(obj.cate === 'event_icon14') _tag = '<img src="/materials/img/event/event_icon14.png" alt="">';
if(obj.cate === 'event_icon15') _tag = '<img src="/materials/img/event/event_icon15.png" alt="">';
if(obj.cate === 'event_icon16') _tag = '<img src="/materials/img/event/event_icon16.png" alt="">';
if(obj.cate === 'event_icon17') _tag = '<img src="/materials/img/event/event_icon17.png" alt="">';
if(obj.cate === 'event_icon18') _tag = '<img src="/materials/img/event/event_icon18.png" alt="">';
if(obj.cate === 'event_icon19') _tag = '<img src="/materials/img/event/event_icon19.png" alt="">';
if(obj.cate === 'event_icon20') _tag = '<img src="/materials/img/event/event_icon20.png" alt="">';
if(obj.cate === 'event_icon21') _tag = '<img src="/materials/img/event/event_icon21.png" alt="">';
if(obj.cate === 'event_icon22') _tag = '<img src="/materials/img/event/event_icon22.png" alt="">';

     c[key] += '<li><a href="'+obj.url+'"><span class="event_icon">'+_tag+'</span><span class="event_title">'+obj.title+'</span></a></li>';
   }
  var ksasan = 3;
  var ls = _cal + '<div class="day_event"><ul>';
  var _k = new Date();
  var key= new Date(_k.getFullYear(),_k.getMonth(),_k.getDate(),0,0).getTime()/1000;
  for(var i=0;i < ksasan;i++){
    day = new Date(key*1000);
    y   = day.getFullYear();
    m   = day.getMonth() + 1;
    d   = day.getDate();
    ls += "<h4>"+ y + "年" + m + "月" + d + "日（" + get_week(y,m,d) + "）</h4>";
    if(typeof c[key] === "undefined"){
      ls += "<p>掲載はありません。</p>";
    }else{
      ls += c[key];
    }
    key += 24*60*60;
  }
  ls += '</ul></div>';
  console.log(ls);
  $('#calendar').prepend(ls);
});
