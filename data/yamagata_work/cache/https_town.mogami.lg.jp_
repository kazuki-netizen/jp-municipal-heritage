		dots: true,
		autoplaySpeed: 5000,
		arrows: false,
		appendDots: $('.dots-2'),
		asNavFor: textSlider,
	});

	$('.ent-slide-txt').slick({
		fade: true,
		dots: false,
		autoplaySpeed: 5000,
		arrows: false,
		asNavFor: mainSlider
	});
	
